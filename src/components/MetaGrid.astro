---
/**
 * MetaGrid — Bilingual Specifications Grid
 *
 * Parses the raw markdown list of technical specs authored in Obsidian:
 *   - **项目类型**：厂房 / **Project Type**: Factory Building
 *
 * Renders them as a horizontal multi-column grid where each item has a
 * subtle left-border hairline separator — archival, not a table.
 */

interface Props {
  /** Raw markdown body string from Astro content collection */
  rawBody: string;
}

const { rawBody } = Astro.props;

// ── Parse: extract the first unordered list block ──────────────────────────
// Match lines starting with "- " up to the first blank line after the list
const listBlockMatch = rawBody.match(/^(- .+\n?)+/m);
const listBlock = listBlockMatch ? listBlockMatch[0] : '';

interface SpecItem {
  zhLabel: string;
  zhValue: string;
  enLabel: string;
  enValue: string;
}

const items: SpecItem[] = [];

if (listBlock) {
  const lines = listBlock.trim().split('\n');

  for (const line of lines) {
    // Strip leading "- " and inline bold markers
    const stripped = line.replace(/^-\s+/, '').replace(/\*\*/g, '');

    // Pattern: "中文标签：中文值 / English Label: English Value"
    // The separator between ZH and EN portions is " / "
    const dividerIdx = stripped.indexOf(' / ');
    if (dividerIdx === -1) continue;

    const zhPart = stripped.slice(0, dividerIdx).trim();
    const enPart = stripped.slice(dividerIdx + 3).trim();

    // Split each part on the first ：or :
    const zhColon = zhPart.search(/[：:]/);
    const enColon = enPart.indexOf(':');

    if (zhColon === -1 || enColon === -1) continue;

    items.push({
      zhLabel: zhPart.slice(0, zhColon).trim(),
      zhValue: zhPart.slice(zhColon + 1).trim(),
      enLabel: enPart.slice(0, enColon).trim(),
      enValue: enPart.slice(enColon + 1).trim(),
    });
  }
}
---

{items.length > 0 && (
  <dl class="meta-grid">
    {items.map((item) => (
      <div class="meta-item">
        <dt class="meta-label">
          <span class="meta-label-zh">{item.zhLabel}</span>
          <span class="meta-label-en">{item.enLabel}</span>
        </dt>
        <dd class="meta-value">
          <span class="meta-value-zh">{item.zhValue}</span>
          <span class="meta-value-en">{item.enValue}</span>
        </dd>
      </div>
    ))}
  </dl>
)}

<style>
  .meta-grid {
    display: grid;
    /* Fluid columns: each at least 160px, auto-filling */
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 0;
    margin: 2.5rem 0 3.5rem;
    padding: 0;
    border-top: 1px solid var(--c-rule);
    border-bottom: 1px solid var(--c-rule);
  }

  .meta-item {
    padding: 1.25rem 1.5rem 1.25rem 1rem;
    border-left: 1px solid #111111; /* the fine separator called for in the brief */
  }
  .meta-item:first-child {
    border-left: none;
    padding-left: 0;
  }

  dt.meta-label {
    display: flex;
    flex-direction: column;
    gap: 1px;
    margin: 0 0 0.35rem;
  }
  .meta-label-zh {
    font-family: var(--ff-serif);
    font-size: var(--fs-xs);
    letter-spacing: 0.08em;
    color: var(--c-mid);
  }
  .meta-label-en {
    font-family: var(--ff-caps);
    font-size: 6.5pt;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-rule);
  }

  dd.meta-value {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .meta-value-zh {
    font-family: var(--ff-serif);
    font-size: var(--fs-sm);
    font-weight: 500;
    color: var(--c-ink);
    line-height: 1.4;
  }
  .meta-value-en {
    font-family: var(--ff-serif);
    font-size: 7.5pt;
    color: var(--c-mid);
    line-height: 1.4;
  }
</style>
