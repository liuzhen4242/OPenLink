---
/**
 * /projects/[...slug] — Project detail page
 *
 * In Astro v7 Content Layer API, entries use `id` (the file path relative to
 * the glob base, e.g. "Projects/Xinjiang-museum/Xinjiang-museum.md") instead
 * of the legacy `slug`.
 *
 * We derive:
 * • URL slug:      "Projects/Xinjiang-museum/Xinjiang-museum"  (no .md)
 * • Project dir:   "Projects/Xinjiang-museum"                  (directory)
 * • Image base:    /project-images/<projectDir>/images/  (static, works
 *   identically in `astro dev`, `astro build`, and on Netlify — populated
 *   by scripts/sync-project-images.mjs, which runs automatically before
 *   both `npm run dev` and `npm run build`)
 *
 * Features:
 * • MetaGrid: parses Obsidian bilingual spec list → horizontal grid
 * • Full-width architectural drawings (margin: 3.5rem 0 via .prose img rule)
 * • Runtime image rewriting: body <img> src attrs → /project-images/ paths
 * • Gallery slider: ```gallery code blocks are converted at build time
 *   (see remarkGalleryPlugin in astro.config.mjs) into `.gallery-slider`
 *   divs; the script below adds the carousel behavior client-side.
 *
 * NOTE: the frontmatter `coverImage` is intentionally NOT rendered on this
 * page — it's only used as the thumbnail on the /projects listing page
 * (see src/pages/projects/index.astro). The detail page goes straight from
 * the header into the article body.
 */
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import MetaGrid from '../../components/MetaGrid.astro';
import 'photoswipe/style.css';

/** Convert entry id → URL slug (strip .md extension and leading Projects/) */
function idToSlug(id: string): string {
  return id.replace(/\.md$/, '').replace(/^[Pp]rojects\//, '');
}

/** Extract the project directory from entry id */
function idToProjectDir(id: string): string {
  const parts = id.replace(/\.md$/, '').split('/');
  parts.pop();
  return parts.join('/');
}

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => {
    // Convert entry id → URL slug (strip .md extension and leading Projects/)
    const slug = project.id.replace(/\.md$/, '').replace(/^[Pp]rojects\//, '');
    return {
      params: { slug },
      props:  { project },
    };
  });
}

const { project } = Astro.props;
const { data, body } = project;

const { Content, headings } = await render(project);

const projectDir = idToProjectDir(project.id);

/**
 * Build a nested outline from the flat `headings` array Astro's render()
 * gives us — h3 (### in the source note) becomes a top-level item, and any
 * h4 immediately following is nested under it. Mirrors the outline you'd
 * see in Obsidian's own sidebar. h1/h2 and anything deeper than h4 is
 * ignored to keep the sidebar readable.
 */
const tocItems: { slug: string; text: string; children: { slug: string; text: string }[] }[] = [];
for (const heading of headings) {
  if (heading.depth === 3) {
    tocItems.push({ slug: heading.slug, text: heading.text, children: [] });
  } else if (heading.depth === 4 && tocItems.length > 0) {
    tocItems[tocItems.length - 1].children.push({ slug: heading.slug, text: heading.text });
  }
}
---

<BaseLayout title={data.title} description={data.description}>

  <div class="project-layout">
    <div class="project-main">
      <!-- ── Project header ─────────────────────────────── -->
      <header class="project-header">
        <div class="project-super">
          <span class="project-category">{data.category}</span>
          {data.date && <span class="project-date">{data.date}</span>}
        </div>
        <h1 class="project-title">{data.title}</h1>
        {data.description && (
          <p class="project-desc">{data.description}</p>
        )}
      </header>

      <!-- ── Bilingual metadata grid ────────────────────── -->
      {body && <MetaGrid rawBody={body} />}

      <!-- ── Markdown body (drawings, prose) ────────────── -->
      <article class="prose">
        <Content />
      </article>

      <!-- Back link -->
      <nav class="back-nav">
        <a href="/projects" class="back-link">
          <span aria-hidden="true">←</span>&ensp;所有项目
        </a>
      </nav>
    </div>

    {tocItems.length > 0 && (
      <aside class="project-toc">
        <h2 class="toc-label">Outline</h2>


        <nav>
          <ul class="toc-list">
            {tocItems.map((item) => (
              <li class="toc-item">
                <a
                  href={`#${item.slug}`}
                  class="toc-parent"
                  data-toc-parent={item.slug}
                  data-toc-link={item.slug}
                >
                  {item.text}
                </a>

                {item.children.length > 0 && (
                  <ul
                    class="toc-sublist collapsed"
                    data-toc-sublist={item.slug}
                  >
                    {item.children.map((child) => (
                      <li>
                        <a
                          href={`#${child.slug}`}
                          data-toc-link={child.slug}
                        >
                          {child.text}
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))}
          </ul>
        </nav>


      </aside>
    )}
  </div>
</BaseLayout>



<!--
  Rewrite relative Obsidian image src attributes at runtime, as a safety
  net for any <img> tags that reach the browser with a bare/unrewritten
  relative path. Points at /project-images/, a plain static folder that
  scripts/sync-project-images.mjs populates from src/content/projects/*/images
  before both `npm run dev` and `npm run build` — this works identically
  in local dev, `astro preview`, and on Netlify.
-->
<script define:vars={{ projectDir }}>
  document.addEventListener('DOMContentLoaded', () => {
    const prose = document.querySelector('.prose');
    if (!prose) return;

    prose.querySelectorAll('img').forEach((img) => {
      const src = img.getAttribute('src') || '';
      // Skip external URLs, data URIs, and paths already rewritten to /project-images/
      if (src.startsWith('http') || src.startsWith('data:') || src.startsWith('/project-images/')) return;
      const raw = decodeURIComponent(src);
      const filename = raw.split('/').pop() || raw;
      if (!filename) return;
      img.src = `/project-images/${projectDir}/images/${encodeURIComponent(filename)}`;
    });
  });
</script>

<!--
  Gallery slider carousel behavior.
  The actual <img> tags & their resolved /project-images/ src paths are
  produced at build time by remarkGalleryPlugin (see astro.config.mjs),
  which turns ```gallery code blocks into `<div class="gallery-slider">`
  markup with one <img> per line. This script just adds the interactive
  cycling — equivalent to what the Obsidian "Gallery Slider" plugin does
  live inside Obsidian's own editor.
-->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Resolves once an <img> is fully decoded and ready to paint —
    // NOT just once its bytes have finished downloading. Those are two
    // different moments: `load`/`complete` only guarantee the network
    // fetch is done, but decoding a large photo into pixels the browser
    // can actually draw takes its own extra time. That gap is exactly
    // what caused the blank/half-rendered flash on slide changes, even
    // though the "preload" step had technically already finished.
    // img.decode() waits for the real thing: fully decoded, paint-ready.
    function whenSettled(img) {
      if (typeof img.decode === 'function') {
        return img.decode().catch(() => {}); // treat decode errors as "done trying"
      }
      if (img.complete) return Promise.resolve();
      return new Promise((resolve) => {
        img.addEventListener('load', resolve, { once: true });
        img.addEventListener('error', resolve, { once: true });
      });
    }

    document.querySelectorAll('.gallery-slider').forEach((wrapper) => {
      const imgs = Array.from(wrapper.querySelectorAll('img'));
      if (imgs.length === 0) return;

      // Single-image galleries don't need a timer, just show the one image.
      if (imgs.length === 1) {
        imgs[0].classList.add('is-active');
        return;
      }

      let index = imgs.findIndex((img) => img.classList.contains('is-active'));
      if (index < 0) index = 0;
      let playing = true;

      function show(i) {
        imgs.forEach((img, j) => img.classList.toggle('is-active', j === i));
      }

      // Instead of waiting for every photo in the gallery to be ready
      // before starting anything, each cycle only waits for the ONE image
      // it's about to reveal — capped at 8s so a slow/broken image can't
      // stall the carousel forever. This starts playing much sooner on
      // large galleries while still guaranteeing we never swap to a slide
      // that isn't actually ready yet (no blank/half-rendered flash).
      async function tick() {
        if (playing) {
          const nextIndex = (index + 1) % imgs.length;
          await Promise.race([
            whenSettled(imgs[nextIndex]),
            new Promise((resolve) => window.setTimeout(resolve, 8000)),
          ]);
          if (playing) {
            index = nextIndex;
            show(index);
          }
        }
        window.setTimeout(tick, 3000);
      }

      show(index);
      window.setTimeout(tick, 3000);

      wrapper.addEventListener('mouseenter', () => {
        playing = false;
      });
      wrapper.addEventListener('mouseleave', () => {
        playing = true;
      });
    });
  });
</script>

<!--
  PhotoSwipe lightbox: clicking any image in the article opens it zoomed in
  from its exact on-page position (PhotoSwipe's signature transition), and
  every image in the article is one navigable sequence — tapping the open
  photo advances to the next one (tapAction: 'next'), and Esc closes, both
  built into PhotoSwipe with no extra code needed.
-->
<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';

  document.addEventListener('DOMContentLoaded', () => {
    const lightbox = new PhotoSwipeLightbox({
      gallery: '.prose',
      children: 'img',
      pswpModule: () => import('photoswipe'),
      tapAction: 'next',
    });

    // PhotoSwipe needs each image's real pixel dimensions to animate the
    // zoom smoothly. Since every image is already rendered on the page by
    // the time someone clicks it, we can just read its actual decoded size
    // right before it opens rather than pre-computing this at build time.
    lightbox.addFilter('itemData', (itemData) => {
      const el = itemData.element;
      if (el instanceof HTMLImageElement) {
        itemData.src = el.currentSrc || el.src;
        itemData.width = el.naturalWidth || 1600;
        itemData.height = el.naturalHeight || 1067;
      }
      return itemData;
    });

    lightbox.init();
  });
</script>

<script>
document.addEventListener('DOMContentLoaded', () => {

  document.querySelectorAll('.toc-parent')
    .forEach(link => {

      link.addEventListener('click', () => {

        const slug = link.dataset.tocParent;

        const sublist =
          document.querySelector(
            `[data-toc-sublist="${slug}"]`
          );

        if (!sublist) return;

        sublist.classList.toggle('collapsed');
      });

    });

});
</script>




<style>
  /* ── Two-column layout: article + outline sidebar ─── */
  .project-layout {
    display: flex;
    align-items: flex-start;
    gap: 4rem;
  }
  .project-main {
    flex: 1;
    min-width: 0;
  }

  /* ── Project header ──────────────────────────────── */
  .project-header {
    padding: 4rem 0 2.5rem;
    border-bottom: 1px solid var(--c-rule);
    margin-bottom: 0;
  }
  .project-super {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1rem;
  }
  .project-category {
    font-family: var(--ff-caps);
    font-size: var(--fs-xs);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--c-mid);
  }
  .project-date {
    font-family: var(--ff-serif);
    font-size: var(--fs-xs);
    color: var(--c-mid);
    font-variant-numeric: tabular-nums;
  }
  .project-date::before {
    content: '—';
    margin-right: 0.5em;
    color: var(--c-rule);
  }

  .project-title {
    font-family: var(--ff-caps);
    font-size: 22pt;
    font-weight: 400;
    letter-spacing: 0.04em;
    color: var(--c-ink);
    margin: 0 0 0.75rem;
    line-height: 1.2;
  }
  .project-desc {
    font-family: var(--ff-serif);
    font-size: var(--fs-sm);
    color: var(--c-mid);
    margin: 0;
    font-style: italic;
  }

  /* ── Prose: full-width drawings ──────────────────── */
  .prose { max-width: none; }
  :global(.prose img) {
    cursor: zoom-in;
  }

  /* ── Back navigation ──────────────────────────────── */
  .back-nav {
    margin-top: 6rem;
    padding-top: 2rem;
    border-top: 1px solid var(--c-rule);
  }
  .back-link {
    font-family: var(--ff-caps);
    font-size: var(--fs-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-mid);
    transition: color 0.18s ease;
  }
  .back-link:hover { color: var(--c-ink); }

  /* ── Outline sidebar ──────────────────────────────── */
  .project-toc {
    width: 200px;
    flex-shrink: 0;
    position: sticky;
    top: 6rem;
    padding-top: 4rem; /* roughly align with the article header */
  }
  .toc-label {
    font-family: var(--ff-caps);
    font-size: var(--fs-xs);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--c-mid);
    font-weight: 400;
    margin: 0 0 1.25rem;
  }
  .toc-list, .toc-sublist {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .toc-list > li {
    margin-bottom: 0.5rem;
  }
 
  .toc-list a {
  display: block;
  font-family: var(--ff-serif);
  font-size: var(--fs-sm);
  color: var(--c-mid);
  padding: 0.15rem 0;
  transition: color 0.18s ease;
}

  .toc-parent {
    cursor: pointer;
  }

  .toc-list a:hover { color: var(--c-ink); }
  .toc-list a.active {
    color: var(--c-ink);
    font-weight: 500;
  }
  
.toc-sublist {
  margin-left: 0.8rem;
  margin-top: 0.25rem;

  overflow: hidden;
  max-height: 500px;
  opacity: 1;

  transition:
    max-height 0.2s ease,
    opacity 0.2s ease;
}

.toc-sublist.collapsed {
  max-height: 0;
  opacity: 0;
}




  .toc-sublist a {
    font-size: var(--fs-xs);
  }

  @media (max-width: 900px) {
    .project-toc { display: none; }
  }

  /*
    ── Collapsible ### sections (Obsidian-style folding) ─────────────
    :global() is required because .toc-section/.section-toggle/etc are
    built by client-side JS at runtime (see the accordion script above),
    not written directly in this component's template, so they never
    receive Astro's scoped-style data attribute — same reasoning as the
    .gallery-slider rules below.

    The expand/collapse animation uses the CSS grid-template-rows 0fr↔1fr
    trick rather than a fixed max-height: it animates correctly no matter
    how tall the content actually is (including images that finish loading
    after the section is opened), with no JS height measurement needed.
  */
  
  
  :global(.section-toggle h3) {
    margin: 0 !important;
  }
  
  :global(.toc-section.is-open .section-chevron) {
    transform: rotate(90deg);
  }
  
  :global(.toc-section.is-open .section-collapse) {
    grid-template-rows: 1fr;
  }
  
  :global(.section-inner > :first-child) {
    margin-top: 0;
  }
  :global(.section-inner > :last-child) {
    margin-bottom: 0;
    padding-bottom: 2rem;
  }

  /*
    ── Gallery slider ────────────────────────────────
    :global() is required here because the .gallery-slider markup is
    injected as raw HTML from the remark plugin (not through Astro's
    template), so it never receives Astro's scoped-style data attribute.
  */
  :global(.gallery-slider) {
    position: relative;
    width: 100%;
    margin: 3.5rem 0;
    cursor: pointer;
  }
  :global(.gallery-slider img) {
    width: 100%;
    height: auto;
    display: none;
    border-radius: 0;
  }
  :global(.gallery-slider img.is-active) {
    display: block;
  }
  :global(.gallery-empty) {
    color: var(--c-mid);
    font-style: italic;
  }
</style>