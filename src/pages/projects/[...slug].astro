---
/**
 * /projects/[...slug] — Project detail page
 *
 * In Astro v7 Content Layer API, entries use `id` (the file path relative to
 * the glob base, e.g. "Projects/Xinjiang-museum/Xinjiang-museum.md") instead
 * of the legacy `slug`.
 *
 * We derive:
 * • URL slug:      "Projects/Xinjiang-museum/Xinjiang-museum"  (no .md)
 * • Project dir:   "Projects/Xinjiang-museum"                  (directory)
 * • Image base:    /project-images/<projectDir>/images/  (static, works
 *   identically in `astro dev`, `astro build`, and on Netlify — populated
 *   by scripts/sync-project-images.mjs, which runs automatically before
 *   both `npm run dev` and `npm run build`)
 *
 * Features:
 * • MetaGrid: parses Obsidian bilingual spec list → horizontal grid
 * • Full-width architectural drawings (margin: 3.5rem 0 via .prose img rule)
 * • Runtime image rewriting: body <img> src attrs → /project-images/ paths
 * • Gallery slider: ```gallery code blocks are converted at build time
 *   (see remarkGalleryPlugin in astro.config.mjs) into `.gallery-slider`
 *   divs; the script below adds the carousel behavior client-side.
 */
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import MetaGrid from '../../components/MetaGrid.astro';

/** Convert entry id → URL slug (strip .md extension and leading Projects/) */
function idToSlug(id: string): string {
  return id.replace(/\.md$/, '').replace(/^[Pp]rojects\//, '');
}

/** Extract the project directory from entry id */
function idToProjectDir(id: string): string {
  const parts = id.replace(/\.md$/, '').split('/');
  parts.pop();
  return parts.join('/');
}

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => {
    // Convert entry id → URL slug (strip .md extension and leading Projects/)
    const slug = project.id.replace(/\.md$/, '').replace(/^[Pp]rojects\//, '');
    return {
      params: { slug },
      props:  { project },
    };
  });
}

const { project } = Astro.props;
const { data, body } = project;

const { Content } = await render(project);

const projectDir = idToProjectDir(project.id);

// ✨ 核心改变：安全提取被 Astro image() 处理器编译后的封面 URL 字符串
const coverObj = (data as any).coverImage;
const coverUrl = typeof coverObj === 'object' && coverObj !== null ? (coverObj as any).src : coverObj;
---

<BaseLayout title={data.title} description={data.description}>

  <!-- ── Project header ─────────────────────────────── -->
  <header class="project-header">
    <div class="project-super">
      <span class="project-category">{data.category}</span>
      {data.date && <span class="project-date">{data.date}</span>}
    </div>
    <h1 class="project-title">{data.title}</h1>
    {data.description && (
      <p class="project-desc">{data.description}</p>
    )}
  </header>

  <!-- ── Hero cover image ───────────────────────────── -->
  {coverUrl && (
    <div class="project-hero">
      <img src={coverUrl} alt={data.title} />
    </div>
  )}

  <!-- ── Bilingual metadata grid ────────────────────── -->
  {body && <MetaGrid rawBody={body} />}

  <!-- ── Markdown body (drawings, prose) ────────────── -->
  <article class="prose">
    <Content />
  </article>

  <!-- Back link -->
  <nav class="back-nav">
    <a href="/projects" class="back-link">
      <span aria-hidden="true">←</span>&ensp;所有项目
    </a>
  </nav>
</BaseLayout>

<!--
  Rewrite relative Obsidian image src attributes at runtime, as a safety
  net for any <img> tags that reach the browser with a bare/unrewritten
  relative path. Points at /project-images/, a plain static folder that
  scripts/sync-project-images.mjs populates from src/content/projects/*/images
  before both `npm run dev` and `npm run build` — this works identically
  in local dev, `astro preview`, and on Netlify.
-->
<script define:vars={{ projectDir }}>
  document.addEventListener('DOMContentLoaded', () => {
    const prose = document.querySelector('.prose');
    if (!prose) return;

    prose.querySelectorAll('img').forEach((img) => {
      const src = img.getAttribute('src') || '';
      // Skip external URLs, data URIs, and paths already rewritten to /project-images/
      if (src.startsWith('http') || src.startsWith('data:') || src.startsWith('/project-images/')) return;
      const raw = decodeURIComponent(src);
      const filename = raw.split('/').pop() || raw;
      if (!filename) return;
      img.src = `/project-images/${projectDir}/images/${encodeURIComponent(filename)}`;
    });
  });
</script>

<!--
  Gallery slider carousel behavior.
  The actual <img> tags & their resolved /project-images/ src paths are
  produced at build time by remarkGalleryPlugin (see astro.config.mjs),
  which turns ```gallery code blocks into `<div class="gallery-slider">`
  markup with one <img> per line. This script just adds the interactive
  cycling — equivalent to what the Obsidian "Gallery Slider" plugin does
  live inside Obsidian's own editor.
-->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.gallery-slider').forEach((wrapper) => {
      const imgs = Array.from(wrapper.querySelectorAll('img'));
      if (imgs.length === 0) return;

      // Single-image galleries don't need a timer, just show the one image.
      if (imgs.length === 1) {
        imgs[0].classList.add('is-active');
        return;
      }

      let index = imgs.findIndex((img) => img.classList.contains('is-active'));
      if (index < 0) index = 0;
      let playing = true;

      function show(i) {
        imgs.forEach((img, j) => img.classList.toggle('is-active', j === i));
      }

      show(index);

      const timer = window.setInterval(() => {
        if (!playing) return;
        index = (index + 1) % imgs.length;
        show(index);
      }, 3000);

      wrapper.addEventListener('mouseenter', () => {
        playing = false;
      });
      wrapper.addEventListener('mouseleave', () => {
        playing = true;
      });
      wrapper.addEventListener('click', () => {
        playing = !playing;
      });
    });
  });
</script>

<style>
  /* ── Project header ──────────────────────────────── */
  .project-header {
    padding: 4rem 0 2.5rem;
    border-bottom: 1px solid var(--c-rule);
    margin-bottom: 0;
  }
  .project-super {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1rem;
  }
  .project-category {
    font-family: var(--ff-caps);
    font-size: var(--fs-xs);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--c-mid);
  }
  .project-date {
    font-family: var(--ff-serif);
    font-size: var(--fs-xs);
    color: var(--c-mid);
    font-variant-numeric: tabular-nums;
  }
  .project-date::before {
    content: '—';
    margin-right: 0.5em;
    color: var(--c-rule);
  }

  .project-title {
    font-family: var(--ff-caps);
    font-size: 22pt;
    font-weight: 400;
    letter-spacing: 0.04em;
    color: var(--c-ink);
    margin: 0 0 0.75rem;
    line-height: 1.2;
  }
  .project-desc {
    font-family: var(--ff-serif);
    font-size: var(--fs-sm);
    color: var(--c-mid);
    margin: 0;
    font-style: italic;
  }

  /* ── Hero image ──────────────────────────────────── */
  .project-hero {
    margin: 3.5rem 0 0;
    background: #e8e6e1;
  }
  .project-hero img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Prose: full-width drawings ──────────────────── */
  .prose { max-width: none; }

  /* ── Back navigation ──────────────────────────────── */
  .back-nav {
    margin-top: 6rem;
    padding-top: 2rem;
    border-top: 1px solid var(--c-rule);
  }
  .back-link {
    font-family: var(--ff-caps);
    font-size: var(--fs-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-mid);
    transition: color 0.18s ease;
  }
  .back-link:hover { color: var(--c-ink); }

  /*
    ── Gallery slider ────────────────────────────────
    :global() is required here because the .gallery-slider markup is
    injected as raw HTML from the remark plugin (not through Astro's
    template), so it never receives Astro's scoped-style data attribute.
  */
  :global(.gallery-slider) {
    position: relative;
    width: 100%;
    margin: 3.5rem 0;
    cursor: pointer;
  }
  :global(.gallery-slider img) {
    width: 100%;
    height: auto;
    display: none;
    border-radius: 0;
  }
  :global(.gallery-slider img.is-active) {
    display: block;
  }
  :global(.gallery-empty) {
    color: var(--c-mid);
    font-style: italic;
  }
</style>