---
/**
 * /projects — Masonry waterfall gallery
 *
 * CSS-native masonry via column-count: 2 (no JS, no grid hack).
 * Images retain their original aspect ratio for an organic staggered rhythm.
 * Metadata (category · title · year) sits tightly below each image in
 * archival micro-typography (~7.5–9pt).
 *
 * Content: Astro Content Layer collection "projects", sourced from the
 * Obsidian vault symlinked at src/content/projects/Projects/.
 *
 * In Astro v7 Content Layer API, entries use `id` (the file path relative to
 * the glob base) instead of the v4/v5 `slug`.
 * e.g. id = "Projects/Xinjiang-museum/Xinjiang-museum.md"
 */
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allProjects = await getCollection('projects');
const projects = allProjects.sort(
  (a, b) => Number(b.data.date ?? 0) - Number(a.data.date ?? 0)
);

/**
 * Build a URL-safe slug from the entry id.
 * "Projects/Xinjiang-museum/Xinjiang-museum.md" → "Projects/Xinjiang-museum/Xinjiang-museum"
 */
function idToSlug(id: string): string {
  return id.replace(/\.md$/, '').replace(/^[Pp]rojects\//, '');
}

/**
 * Resolve the project directory from the entry id.
 * "Projects/Xinjiang-museum/Xinjiang-museum.md" → "Projects/Xinjiang-museum"
 */
function idToProjectDir(id: string): string {
  const parts = id.replace(/\.md$/, '').split('/');
  parts.pop(); // remove the filename
  return parts.join('/');
}

/**
 * Build an /@fs/ URL that Vite serves for a cover image.
 * Works because vite.server.fs.allow includes the vault root.
 */
function resolveCoverUrl(id: string, coverImage: string | undefined): string | null {
  if (!coverImage) return null;
  const projectDir = idToProjectDir(id);
  const rel = coverImage.replace(/^\.\//, '');
  return `/@fs/Users/zhenliu/study/coding/OpenLink/src/content/projects/${projectDir}/${rel}`;
}
---

<BaseLayout title="项目" description="建筑与设计作品集">
  <!-- Page header -->
  <header class="gallery-header">
    <p class="gallery-sub">Architecture &amp; Design</p>
    <h1 class="gallery-title">Projects</h1>
  </header>

  {projects.length === 0 ? (
    <p class="empty-state">
      暂无项目 — 请在 Obsidian vault 中添加带有正确 frontmatter 的 Markdown 文件。
    </p>
  ) : (
    <div class="masonry">
      {projects.map((project) => {
        // coverImage is not in schema (to bypass Astro v7 content-assets), use raw data
        const coverUrl = resolveCoverUrl(project.id, (project.data as any).coverImage);
        const slug     = idToSlug(project.id);
        const href     = `/projects/${slug}`;

        return (
          <a href={href} class="masonry-item">
            {coverUrl ? (
              <div class="card-img-wrap">
                <img
                  src={coverUrl}
                  alt={project.data.title}
                  loading="lazy"
                  decoding="async"
                />
              </div>
            ) : (
              <div class="card-img-placeholder">
                <span>—</span>
              </div>
            )}
            <div class="card-meta">
              <span class="card-category">{project.data.category}</span>
              <span class="card-sep">·</span>
              <span class="card-title">{project.data.title}</span>
              {project.data.date && (
                <span class="card-year">{project.data.date}</span>
              )}
            </div>
          </a>
        );
      })}
    </div>
  )}
</BaseLayout>

<style>
  /* ── Page header ─────────────────────────────────── */
  .gallery-header {
    padding: 4rem 0 3rem;
    border-bottom: 1px solid var(--c-rule);
    margin-bottom: 3rem;
  }
  .gallery-sub {
    font-family: var(--ff-caps);
    font-size: var(--fs-xs);
    letter-spacing: 0.18em;
    color: var(--c-mid);
    margin: 0 0 0.4rem;
    text-transform: uppercase;
  }
  .gallery-title {
    font-family: var(--ff-caps);
    font-size: 28pt;
    font-weight: 400;
    letter-spacing: 0.06em;
    color: var(--c-ink);
    margin: 0;
    line-height: 1.1;
  }

  /* ── CSS Masonry (native column-count) ──────────── */
  .masonry {
    column-count: 2;
    column-gap: 2.5rem;
  }

  .masonry-item {
    display: block;
    break-inside: avoid;
    margin-bottom: 3rem;
    cursor: pointer;
    color: inherit;
  }

  /* Image wrapper — no fixed height, natural aspect ratio preserved */
  .card-img-wrap {
    width: 100%;
    overflow: hidden;
    background: #ebe9e4;
  }
  .card-img-wrap img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.45s ease, opacity 0.3s ease;
  }
  .masonry-item:hover .card-img-wrap img {
    transform: scale(1.018);
    opacity: 0.92;
  }

  .card-img-placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: #e8e6e1;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--c-mid);
    font-size: 1.5rem;
  }

  /* Tight archival metadata row */
  .card-meta {
    margin-top: 0.6rem;
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.3rem;
    font-family: var(--ff-serif);
    font-size: var(--fs-xs);
    letter-spacing: 0.05em;
    color: var(--c-mid);
    line-height: var(--lh-tight);
  }
  .card-category {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 6.5pt;
  }
  .card-sep { color: var(--c-rule); }
  .card-title {
    color: var(--c-ink);
    font-size: 9pt;
    font-weight: 500;
    flex: 1;
  }
  .card-year {
    margin-left: auto;
    font-variant-numeric: tabular-nums;
    color: var(--c-mid);
    font-size: 7pt;
  }

  /* ── Empty state ──────────────────────────────── */
  .empty-state {
    margin-top: 4rem;
    font-size: var(--fs-sm);
    color: var(--c-mid);
    font-style: italic;
  }

  /* ── Responsive: single column on narrow screens ── */
  @media (max-width: 640px) {
    .masonry { column-count: 1; }
    .gallery-title { font-size: 20pt; }
  }
</style>
